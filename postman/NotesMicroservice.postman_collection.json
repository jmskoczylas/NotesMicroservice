{
  "info": {
    "_postman_id": "3e6753ac-6d6d-4ee5-9da4-9eb529be9f95",
    "name": "NotesMicroservice",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Note",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 201) {",
              "  var json = pm.response.json();",
              "  if (json.id !== undefined) pm.collectionVariables.set('noteId', json.id);",
              "  if (json.noteVersion !== undefined) pm.collectionVariables.set('noteVersion', json.noteVersion);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 0,\n  \"title\": \"First note\",\n  \"text\": \"Created from Postman.\",\n  \"createdOn\": null,\n  \"modifiedOn\": null,\n  \"noteVersion\": 0,\n  \"deletedOn\": null\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/Note",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Note"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Note By Id",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "  var json = pm.response.json();",
              "  if (json.noteVersion !== undefined) pm.collectionVariables.set('noteVersion', json.noteVersion);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Note/{{noteId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "Note",
            "{{noteId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Notes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/Note?page=1&pageSize=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
