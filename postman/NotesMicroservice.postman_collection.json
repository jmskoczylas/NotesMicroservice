              "  var json = pm.response.json();",
              "  if (json.noteVersion !== undefined) pm.collectionVariables.set('noteVersion', json.noteVersion);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{noteId}},\n  \"title\": \"First note updated\",\n  \"text\": \"Updated from Postman.\",\n  \"createdOn\": null,\n  \"modifiedOn\": null,\n  \"noteVersion\": {{noteVersion}},\n  \"deletedOn\": null\n}"
        },
